# Copy this file to .env and fill in your Supabase project's values.
# Find both under Supabase Dashboard -> Settings -> API.
# These are safe to embed in a client app: access is enforced by
# Row Level Security policies (see supabase/migration_001_init.sql),
# not by keeping this key secret.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: crash reporting. Leave unset to disable — the app runs identically
# either way. Find your DSN under Sentry -> Project Settings -> Client Keys.
EXPO_PUBLIC_SENTRY_DSN=
